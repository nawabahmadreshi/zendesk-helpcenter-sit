{
  "manifest_version": 3,
  "name": "Aquera AI Help",
  "version": "1.0",
  "description": "Agentic AI help widget for the Aquera platform.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Aquera AI Help Settings"
  }
}
